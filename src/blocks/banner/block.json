{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "dlnorrisbooks/banner",
	"version": "0.1.0",
	"title": "Page Banner",
	"category": "dlnorrisbooks",
	"icon": "cover-image",
	"description": "A full-bleed image banner with a centered label card. Reusable page hero across the site.",
	"keywords": [ "banner", "hero", "cover", "header", "page" ],
	"textdomain": "dlnorrisbooks",
	"attributes": {
		"align": { "type": "string", "default": "full" },
		"label": { "type": "string", "default": "Meet the Author" },
		"imageId": { "type": "number", "default": 0 },
		"imageUrl": { "type": "string", "default": "" },
		"imageAlt": { "type": "string", "default": "" },
		"focalPoint": {
			"type": "object",
			"default": { "x": 0.5, "y": 0.5 }
		}
	},
	"supports": {
		"align": [ "full" ],
		"anchor": true,
		"html": false
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
