{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "dlnorrisbooks/section",
	"version": "0.1.0",
	"title": "Section Band",
	"category": "dlnorrisbooks",
	"icon": "align-center",
